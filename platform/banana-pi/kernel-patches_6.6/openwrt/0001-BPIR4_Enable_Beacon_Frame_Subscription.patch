From: Rakhil P E <rakhilpe001@gmail.com>
Date: Wed, 18 Mar 2026 12:02:35 +0000
Subject: [PATCH] Enable beacon reception in station mode

This patch enables reception of beacon frames in station mode
by modifying default management frame subtypes.

---
 build_dir/target-aarch64_cortex-a53_musl/linux-mediatek_filogic/mac80211-regular/backports-6.16/net/mac80211/main.c       | 2 ++
 1 file changed, 2 insertions(+)


--- /build_dir/target-aarch64_cortex-a53_musl/linux-mediatek_filogic/mac80211-regular/backports-6.16/net/mac80211/main.c.orig	2026-03-18 10:53:43.329164006 +0530
+++ /build_dir/target-aarch64_cortex-a53_musl/linux-mediatek_filogic/mac80211-regular/backports-6.16/net/mac80211/main.c	2026-03-18 10:54:13.133527006 +0530
@@ -695,7 +695,8 @@
 		 */
 		.rx = BIT(IEEE80211_STYPE_ACTION >> 4) |
 			BIT(IEEE80211_STYPE_AUTH >> 4) |
-			BIT(IEEE80211_STYPE_PROBE_REQ >> 4),
+			BIT(IEEE80211_STYPE_PROBE_REQ >> 4) |
+			BIT(IEEE80211_STYPE_BEACON >> 4),
 	},
 	[NL80211_IFTYPE_AP] = {
 		.tx = 0xffff,
